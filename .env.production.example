# Production Environment Configuration
# Copy this file to .env.production and update with your actual values

# Django Settings
SECRET_KEY=your-very-secret-key-here
DEBUG=False
ALLOWED_HOSTS=mushqila.com,www.mushqila.com,localhost,127.0.0.1

# Database Configuration
DB_NAME=mushqila
DB_USER=postgres
DB_PASSWORD=your-database-password
DB_HOST=localhost
DB_PORT=5432

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@mushqila.com

# Redis Configuration
REDIS_URL=redis://localhost:6379/1

# Security Settings
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# CORS Settings
CORS_ALLOWED_ORIGINS=https://mushqila.com,https://www.mushqila.com

# Finance App Settings
FINANCE_OTP_EXPIRE_MINUTES=15
FINANCE_MAX_LOGIN_ATTEMPTS=5
FINANCE_LOCKOUT_DURATION_MINUTES=30
FINANCE_DEFAULT_CREDIT_LIMIT=10000.00
FINANCE_COMMISSION_RATE=0.05

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/mushqila/django.log

# Static and Media Files
STATIC_ROOT=/var/www/mushqila/staticfiles
MEDIA_ROOT=/var/www/mushqila/mediafiles

# JWT Settings
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ACCESS_TOKEN_LIFETIME=3600
JWT_REFRESH_TOKEN_LIFETIME=86400

# Galileo GDS (if needed)
GALILEO_ENABLED=False
GALILEO_USERNAME=
GALILEO_PASSWORD=
GALILEE_PCC=
GALILEE_ENDPOINT=
